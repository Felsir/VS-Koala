{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "compile",
            "type": "shell",
            "command": "npm.cmd",
            "args": [
                "run",
                "compile"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": "$tsc"
        },
        {
            "label": "package",
            "type": "shell",
            "command": "npm.cmd",
            "args": [
                "run",
                "package"
            ],
            "dependsOn": "compile",
            "problemMatcher": []
        }
    ]
}